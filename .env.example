# ═══════════════════════════════════════════════════════════════
# 哲学家画廊 - 本地部署配置
# ═══════════════════════════════════════════════════════════════
# 复制此文件为 .env，填入你的 API 信息，保存后重启服务即可

# 你的 OpenAI 兼容 API Key（必填）
# OpenAI:     sk-xxxxxxxxxxxxxxxxxxxx
# DeepSeek:   sk-xxxxxxxxxxxxxxxxxxxx
# Moonshot:   sk-xxxxxxxxxxxxxxxxxxxx
# 通义千问:   sk-xxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-在此填入你的API_KEY

# API 基础地址（根据你的服务商修改）
# OpenAI:     https://api.openai.com/v1
# DeepSeek:   https://api.deepseek.com/v1
# Moonshot:   https://api.moonshot.cn/v1
# 通义千问:   https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# 模型名称（根据你的服务商修改）
# OpenAI:     gpt-4o-mini / gpt-4o
# DeepSeek:   deepseek-chat
# Moonshot:   moonshot-v1-8k
# 通义千问:   qwen-plus
OPENAI_MODEL=gpt-4o-mini

# 后端服务器端口（默认 3016，一般不需要修改）
PORT=3016
